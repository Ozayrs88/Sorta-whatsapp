# URL of your running Sorta web app
SORTA_URL=https://your-sorta-app.com

# Shared secret — must match WHATSAPP_INTAKE_SECRET in web-production/.env.local
WHATSAPP_INTAKE_SECRET=change-me-to-a-long-random-string

# Optional: override the auth_state directory path.
# On Railway this is set automatically from RAILWAY_VOLUME_MOUNT_PATH — no need to set it.
# AUTH_STATE_PATH=/data/auth_state
